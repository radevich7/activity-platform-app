{
  "name": "activity-platform-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:web": "node dist/activity-platform-client/server/server.mjs",
    "build": "ng build",
    "build:web": "ng build --configuration=production",
    "build:mobile": "ng build --configuration=production --ssr=false --prerender=false --output-mode static && mv dist/activity-platform-client/browser/index.csr.html dist/activity-platform-client/browser/index.html && npx cap sync",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:activity-platform-client": "node dist/activity-platform-client/server/server.mjs",
    "heroku-postbuild": "npm run build:web"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.14",
    "@capacitor/android": "^8.4.0",
    "@capacitor/angular": "^2.0.3",
    "@capacitor/core": "latest",
    "@capacitor/ios": "^8.4.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "@capacitor/cli": "latest",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
